@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="page">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <NavMenu />
    </div>

    <!-- MAIN -->
    <main>

        <!-- TOP BAR -->
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="top-user">👤 @context.User.Identity?.Name</span>
                </Authorized>
            </AuthorizeView>
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <!-- PAGE CONTENT -->
        <article class="content px-4">
            @Body
        </article>

    </main>

</div>

<style>
    /* ── Page shell ── */
    .page {
        display: flex;
        flex-direction: row;
        min-height: 100vh;
        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
    }

    /* ── Sidebar ── */
    .sidebar {
        width: 240px;
        min-height: 100vh;
        background: #111827;
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
    }

    /* ── Main content area ── */
    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: #f9fafb;
        min-width: 0;
    }

    /* ── Top bar ── */
    .top-row {
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 20px;
        background: #ffffff;
        border-bottom: 1px solid #e5e7eb;
        padding: 0 28px;
        flex-shrink: 0;
    }

        .top-row a {
            font-size: 13px;
            color: #6b7280;
            text-decoration: none;
            transition: color 0.15s;
        }

            .top-row a:hover {
                color: #111827;
            }

    .top-user {
        font-size: 13px;
        font-weight: 500;
        color: #374151;
    }

    /* ── Page content ── */
    .content {
        flex: 1;
        padding: 2rem 2.5rem;
    }

    /* ── Mobile ── */
    @@media (max-width: 768px) {
        .page {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            min-height: unset;
            height: auto;
            position: relative;
        }

        .content {
            padding: 1.25rem;
        }
    }
</style>
