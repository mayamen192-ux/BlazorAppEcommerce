@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing

@rendermode InteractiveServer

@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<!-- Brand header -->
<div class="nav-brand">
    <a href="/" class="brand-link">
        <span class="brand-icon">🛒</span>
        <span class="brand-name">BlazorShop</span>
    </a>
</div>

<!-- Mobile toggle -->
<input type="checkbox" id="nav-toggle" class="nav-toggler" />
<label for="nav-toggle" class="nav-toggle-label">☰</label>

<div class="nav-scrollable">
    <nav class="nav-menu">

        <!-- Section: Main -->
        <p class="nav-section-label">Main</p>

        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
            <span class="nav-icon">🏠</span>
            <span>Home</span>
        </NavLink>

        <NavLink class="nav-link" href="/products">
            <span class="nav-icon">🛍️</span>
            <span>Products</span>
        </NavLink>

        <!-- Section: Account (auth-dependent) -->
        <AuthorizeView>
            <Authorized>
                <p class="nav-section-label">Manage</p>

                <NavLink class="nav-link nav-link-accent" href="/AddProduct">
                    <span class="nav-icon">➕</span>
                    <span>Add Product</span>
                </NavLink>

                <p class="nav-section-label">Account</p>

                <div class="nav-user">
                    <span class="nav-icon">👤</span>
                    <span class="nav-username">@context.User.Identity?.Name</span>
                </div>

                <button class="nav-link nav-link-danger" @onclick="LogoutUser">
                    <span class="nav-icon">🚪</span>
                    <span>Logout</span>
                </button>

            </Authorized>

            <NotAuthorized>
                <p class="nav-section-label">Account</p>

                <NavLink class="nav-link" href="/login">
                    <span class="nav-icon">🔑</span>
                    <span>Sign In</span>
                </NavLink>

                <NavLink class="nav-link" href="/signUp">
                    <span class="nav-icon">📝</span>
                    <span>Sign Up</span>
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>

@code {
    private void LogoutUser()
    {
        if (AuthStateProvider is CustomAuthenticationStateProvider customAuth)
        {
            customAuth.Logout();
        }

        Navigation.NavigateTo("/login", forceLoad: false);
    }
}

<style>
    /* ── Brand ── */
    .nav-brand {
        padding: 20px 16px 16px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .brand-link {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
    }

    .brand-icon {
        font-size: 20px;
        line-height: 1;
    }

    .brand-name {
        font-size: 15px;
        font-weight: 600;
        color: #ffffff;
        letter-spacing: 0.2px;
    }

    /* ── Mobile toggle ── */
    .nav-toggler {
        display: none;
    }

    .nav-toggle-label {
        display: none;
        color: rgba(255,255,255,0.7);
        padding: 12px 16px;
        cursor: pointer;
        font-size: 18px;
    }

    /* ── Scrollable nav area ── */
    .nav-scrollable {
        padding: 12px 10px;
        overflow-y: auto;
        flex: 1;
    }

    /* ── Nav menu ── */
    .nav-menu {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    /* ── Section labels ── */
    .nav-section-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.28);
        padding: 14px 8px 4px;
        margin: 0;
    }

    /* ── Nav links ── */
    .nav-link {
        display: flex !important;
        align-items: center;
        gap: 10px;
        padding: 9px 10px !important;
        border-radius: 8px;
        font-size: 13.5px;
        font-weight: 400;
        color: rgba(255,255,255,0.62) !important;
        text-decoration: none !important;
        transition: background 0.15s, color 0.15s;
        width: 100%;
    }

        .nav-link:hover {
            background: rgba(255,255,255,0.07);
            color: #ffffff !important;
        }

        .nav-link.active {
            background: rgba(255,255,255,0.10);
            color: #ffffff !important;
            font-weight: 500;
        }

    /* ── Add Product accent ── */
    .nav-link-accent {
        color: #86efac !important;
        background: rgba(134,239,172,0.08) !important;
        border: 1px solid rgba(134,239,172,0.18);
    }

        .nav-link-accent:hover {
            background: rgba(134,239,172,0.15) !important;
            color: #bbf7d0 !important;
        }

        .nav-link-accent.active {
            background: rgba(134,239,172,0.2) !important;
            color: #bbf7d0 !important;
        }

    /* ── Logout danger ── */
    .nav-link-danger {
        color: rgba(252,165,165,0.75) !important;
    }

        .nav-link-danger:hover {
            background: rgba(252,165,165,0.10) !important;
            color: #fca5a5 !important;
        }

    /* ── Logout button reset (so it looks like a nav link) ── */
    button.nav-link {
        background: none;
        border: none;
        cursor: pointer;
        text-align: left;
        font-family: inherit;
    }

    /* ── Logged-in user display ── */
    .nav-user {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 8px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        margin-bottom: 2px;
    }

    .nav-username {
        font-size: 12.5px;
        color: rgba(255,255,255,0.45);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .nav-icon {
        font-size: 16px;
        flex-shrink: 0;
        width: 20px;
        text-align: center;
    }

    /* ── Mobile ── */
    @@media (max-width: 768px) {
        .nav-toggle-label {
            display: block;
        }

        .nav-scrollable {
            display: none;
        }

        .nav-toggler:checked ~ .nav-scrollable {
            display: block;
        }
    }
</style>