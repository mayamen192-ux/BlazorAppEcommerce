@page "/EditProduct/{id:int}"
@rendermode InteractiveServer

@using BlazorAppEcommerce.DTOs
@using BlazorAppEcommerce.Services

@inject ProductService ProductService
@inject NavigationManager Navigation

<div class="container mt-4">

    <h3>Edit Product</h3>

    @if (loading)
    {
        <p>Loading product...</p>
    }
    else if (!found)
    {
        <div class="alert alert-danger">
            Product not found.
        </div>
    }
    else
    {
        <EditForm Model="editProduct"
                  OnValidSubmit="SaveProduct">

            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label>Name</label>
                <InputText class="form-control"
                           @bind-Value="editProduct.Name" />
            </div>

            <div class="mb-3">
                <label>Price</label>
                <InputNumber class="form-control"
                             @bind-Value="editProduct.Price" />
            </div>

            <div class="mb-3">
                <label>Stock</label>
                <InputNumber class="form-control"
                             @bind-Value="editProduct.Stock" />
            </div>

            <div class="mb-3">
                <label>Description</label>
                <InputTextArea class="form-control"
                               @bind-Value="editProduct.Description" />
            </div>

            <button type="submit" class="btn btn-primary me-2">
                Save Changes
            </button>

            <button type="button"
                    class="btn btn-secondary"
                    @onclick="Cancel">
                Cancel
            </button>

        </EditForm>
    }

</div>

@code {

    [Parameter]
    public int id { get; set; }

    private ProductDOT editProduct = new();

    private bool loading = true;
    private bool found = true;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;

        try
        {
            var result = await ProductService.GetProductById(id);

            if (result == null)
            {
                found = false;
            }
            else
            {
                found = true;
                editProduct = result;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.ToString());
            found = false;
        }

        loading = false;
    }

    private async Task SaveProduct()
    {
        try
        {
            await ProductService.UpdateProduct(editProduct);

            Navigation.NavigateTo("/products", true);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.ToString());
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/products");
    }
}