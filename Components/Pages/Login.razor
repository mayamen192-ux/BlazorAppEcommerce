@page "/login"

@layout Layout.LoginLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer

@inject NavigationManager Navigation
@inject UserService UserService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Sign In – BlazorShop</PageTitle>

<div class="login-wrapper">
    <div class="login-card">

        <div class="login-header">
            <span class="login-icon">🛒</span>
            <h2 class="login-title">Welcome back</h2>
            <p class="login-subtitle">Sign in to your BlazorShop account</p>
        </div>

        @if (!string.IsNullOrEmpty(Message))
        {
            <div class="alert @AlertClass">
                @Message
            </div>
        }

        <div class="form-group">
            <label class="form-label">Email</label>
            <input class="form-control"
                   type="email"
                   placeholder="you@example.com"
                   @bind="Email"
                   @bind:event="oninput" />
        </div>

        <div class="form-group">
            <label class="form-label">Password</label>
            <input class="form-control"
                   type="password"
                   placeholder="••••••••"
                   @bind="Password"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown" />
        </div>

        <button class="btn-login" @onclick="LoginUser" disabled="@isLoading">
            @if (isLoading)
            {
                <span>Signing in…</span>
            }
            else
            {
                <span>Sign In</span>
            }
        </button>

        <p class="signup-hint">
            Don't have an account? <a href="/signUp">Sign Up</a>
        </p>

    </div>
</div>

@code {

    private string Email = "";
    private string Password = "";
    private string Message = "";
    private string AlertClass = "";
    private bool isLoading = false;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await LoginUser();
    }

    private async Task LoginUser()
    {
        try
        {
            Message = "";
            AlertClass = "";

            // ── Validation ──
            if (string.IsNullOrWhiteSpace(Email) ||
                string.IsNullOrWhiteSpace(Password))
            {
                Message = "Please enter your email and password.";
                AlertClass = "alert-danger";
                return;
            }

            isLoading = true;

            // ── Check user ──
            var user = UserService.Login(Email, Password);

            if (user == null)
            {
                Message = "Invalid email or password.";
                AlertClass = "alert-danger";
                return;
            }

            // ── Auth state update (now passes user.Id) ──
            if (AuthStateProvider is CustomAuthenticationStateProvider customAuth)
            {
                await customAuth.MarkUserAsAuthenticated(user.email, user.role, user.Id);
            }

            // ── Success ──
            Message = "Login successful! Redirecting…";
            AlertClass = "alert-success";

            await Task.Delay(300);

            Navigation.NavigateTo("/", forceLoad: false);
        }
        catch (Exception ex)
        {
            Message = $"An error occurred: {ex.Message}";
            AlertClass = "alert-danger";
        }
        finally
        {
            isLoading = false;
        }
    }
}

<style>
    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-image: linear-gradient(rgba(15, 23, 42, 0.55), rgba(15, 23, 42, 0.55)), url('images/login.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        padding: 24px;
    }

    .login-card {
        background: rgba(255, 255, 255, 0.97);
        backdrop-filter: blur(8px);
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.4);
        padding: 40px 36px;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 12px 40px rgba(0,0,0,0.25);
    }

    .login-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .login-icon {
        font-size: 40px;
        display: block;
        margin-bottom: 10px;
    }

    .login-title {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 6px;
    }

    .login-subtitle {
        font-size: 13.5px;
        color: #6b7280;
        margin: 0;
    }

    /* ── Form ── */
    .form-group {
        margin-bottom: 16px;
    }

    .form-label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #374151;
        margin-bottom: 6px;
    }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 14px;
        color: #111827;
        background: #f9fafb;
        transition: border-color 0.15s, box-shadow 0.15s;
        box-sizing: border-box;
    }

        .form-control:focus {
            outline: none;
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79,70,229,0.12);
            background: #ffffff;
        }

    /* ── Button ── */
    .btn-login {
        width: 100%;
        padding: 11px;
        background: #4f46e5;
        color: #ffffff;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 8px;
        transition: background 0.15s;
    }

        .btn-login:hover:not(:disabled) {
            background: #4338ca;
        }

        .btn-login:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

    /* ── Alerts ── */
    .alert {
        padding: 10px 14px;
        border-radius: 8px;
        font-size: 13.5px;
        margin-bottom: 16px;
    }

    .alert-danger {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #b91c1c;
    }

    .alert-success {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #15803d;
    }

    /* ── Sign up hint ── */
    .signup-hint {
        text-align: center;
        font-size: 13px;
        color: #6b7280;
        margin: 16px 0 0;
    }

        .signup-hint a {
            color: #4f46e5;
            font-weight: 500;
            text-decoration: none;
        }

            .signup-hint a:hover {
                text-decoration: underline;
            }
</style>