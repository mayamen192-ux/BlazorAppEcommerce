@page "/signIn"
@layout Layout.LoginLayout
@attribute [AllowAnonymous]

@inject NavigationManager Navigation
@inject UserService UserService
@inject AuthenticationStateProvider AuthStateProvider

<div class="container-fluid h-100 d-flex flex-column justify-content-center align-items-center">

    <!-- Logo -->
    <div class="col-12 text-center mb-4">
        <img src="Codeline.jpg"
             class="img-fluid"
             alt="Logo"
             style="max-width: 100%; height: auto;" />
    </div>

    <!-- Login Card -->
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">

                <div class="card shadow-lg">

                    <div class="card-header text-center bg-primary text-white">
                        <h3>Sign In</h3>
                    </div>

                    <div class="card-body">

                        @if (!string.IsNullOrEmpty(Message))
                        {
                            <div class="alert @AlertClass">
                                @Message
                            </div>
                        }

                        <div class="mb-3">
                            <label>Email</label>
                            <input class="form-control"
                                   type="email"
                                   @bind="Email"
                                   placeholder="Enter your email" />
                        </div>

                        <div class="mb-3">
                            <label>Password</label>
                            <input class="form-control"
                                   type="password"
                                   @bind="Password"
                                   placeholder="Enter your password" />
                        </div>

                        <button class="btn btn-primary w-100"
                                @onclick="LoginUser">
                            Login
                        </button>

                    </div>

                    <div class="card-footer text-center">
                        <p>
                            Don't have an account?
                            <button class="btn btn-link p-0"
                                    @onclick="GoToSignUp">
                                Sign up here
                            </button>
                        </p>
                    </div>

                </div>

            </div>
        </div>
    </div>
</div>

@code {

    private string Email = "";
    private string Password = "";
    private string Message = "";
    private string AlertClass = "";

    private async Task LoginUser()
    {
        try
        {
            // =====================
            // VALIDATION
            // =====================
            if (string.IsNullOrWhiteSpace(Email) ||
                string.IsNullOrWhiteSpace(Password))
            {
                Message = "Please enter email and password";
                AlertClass = "alert-danger";
                return;
            }

            // =====================
            // CHECK USER
            // =====================
            var user = UserService.Login(Email, Password);

            if (user == null)
            {
                Message = "Invalid email or password";
                AlertClass = "alert-danger";
                return;
            }

            // =====================
            // AUTH STATE UPDATE
            // =====================
            if (AuthStateProvider is CustomAuthenticationStateProvider customAuth)
            {
                await customAuth.MarkUserAsAuthenticated(user.email, user.role);
            }

            // =====================
            // SUCCESS MESSAGE
            // =====================
            Message = "Login successful";
            AlertClass = "alert-success";

            await Task.Delay(200);

            // =====================
            // ROLE-BASED REDIRECT
            // =====================
            if (user.role == "Client")
            {
                Navigation.NavigateTo("/home", forceLoad: false);
            }
            else
            {
                Navigation.NavigateTo("/AddProduct", forceLoad: false);
            }
        }
        catch (Exception ex)
        {
            Message = ex.Message;
            AlertClass = "alert-danger";
        }
    }

    private void GoToSignUp()
    {
        Navigation.NavigateTo("/signUp");
    }
}