<Router AppAssembly="@typeof(Program).Assembly">

    <Found Context="routeData">
        <AuthorizeRouteView RouteData="@routeData"
                            DefaultLayout="@typeof(MainLayout)">

            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>

            <Authorizing>
                <MudContainer Class="d-flex justify-center align-center mt-8">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    <MudText Typo="Typo.body1" Class="ml-4">Checking authentication...</MudText>
                </MudContainer>
            </Authorizing>

        </AuthorizeRouteView>
    </Found>

    <NotFound>
        <PageTitle>Not Found</PageTitle>
        <MudContainer>
            <MudPaper Class="pa-8 ma-8 text-center" Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Warning" Size="Size.Large" />
                <MudText Typo="Typo.h4" Class="mt-4">Page Not Found</MudText>
                <MudText Typo="Typo.body1" Class="mt-2">The page you are looking for does not exist.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" Href="/">Go to Home</MudButton>
            </MudPaper>
        </MudContainer>
    </NotFound>

</Router>